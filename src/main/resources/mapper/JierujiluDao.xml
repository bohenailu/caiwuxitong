	<select id="selectListVO"
		resultType="com.entity.vo.JierujiluVO" >
		SELECT * FROM jierujilu  jierujilu         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.JierujiluVO" >
		SELECT  jierujilu.* FROM jierujilu  jierujilu 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.JierujiluView" >

		SELECT  jierujilu.* FROM jierujilu  jierujilu 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.JierujiluView" >
		SELECT * FROM jierujilu  jierujilu <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
</mapper>
