<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.JierujiluDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.JierujiluEntity" id="jierujiluMap">
        <result property="zhanghao" column="zhanghao"/>
        <result property="xingming" column="xingming"/>
        <result property="jieqianduixiang" column="jieqianduixiang"/>
        <result property="jieqianfangshi" column="jieqianfangshi"/>
        <result property="jierujine" column="jierujine"/>
        <result property="jierushijian" column="jierushijian"/>
